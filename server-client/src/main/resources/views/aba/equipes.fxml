<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.unibusiness.controller.aba.EquipesController"
            stylesheets="@../../style/sidebar.css">
    <center>
        <StackPane>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="scroll">
                <content>
                    <VBox spacing="20" styleClass="content">

                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <VBox HBox.hgrow="ALWAYS" spacing="2">
                                <Label text="Equipes" styleClass="page-title"/>
                                <Label text="Gerencie as equipes da empresa" styleClass="page-subtitle"/>
                            </VBox>
                            <Button text="+ Nova Equipe" onAction="#abrirFormNovo" styleClass="btn-primary"/>
                        </HBox>

                        <HBox spacing="14">
                            <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="6">
                                <Label text="Total de equipes" styleClass="kpi-label"/>
                                <Label fx:id="lblTotal" text="—" styleClass="kpi-value"/>
                            </VBox>
                        </HBox>

                        <VBox styleClass="section" spacing="14">
                            <Label text="Equipes cadastradas" styleClass="section-title"/>
                            <TableView fx:id="tabela" prefHeight="400">
                                <columns>
                                    <TableColumn fx:id="colId"    text="#"      prefWidth="80"/>
                                    <TableColumn fx:id="colNome"  text="Nome"   prefWidth="400"/>
                                    <TableColumn fx:id="colAcoes" text="Ações"  prefWidth="180"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </VBox>
                </content>
            </ScrollPane>

            <!-- Form overlay -->
            <StackPane fx:id="formOverlay" visible="false" managed="false"
                       style="-fx-background-color: rgba(15,23,42,0.4);" alignment="CENTER">
                <VBox styleClass="section" maxWidth="400" spacing="16">
                    <Label fx:id="formTitulo" text="Nova Equipe" styleClass="section-title"/>
                    <VBox spacing="6">
                        <Label text="Nome *" styleClass="field-label"/>
                        <TextField fx:id="fNome" promptText="Nome da equipe" styleClass="input"/>
                    </VBox>
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button text="Cancelar" onAction="#fecharForm" styleClass="btn-ghost"/>
                        <Button text="Salvar" onAction="#salvar" styleClass="btn-primary"/>
                    </HBox>
                </VBox>
            </StackPane>

            <StackPane fx:id="loadingOverlay" visible="false" managed="false"
                       styleClass="loading-overlay" alignment="CENTER">
                <StackPane fx:id="customSpinner" styleClass="custom-spinner"/>
            </StackPane>
        </StackPane>
    </center>
</BorderPane>
