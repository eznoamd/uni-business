<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.unibusiness.controller.aba.ChatController"
            stylesheets="@../../style/abas/chat.css">

    <!-- Topbar da conversa aberta -->
    <top>
        <HBox fx:id="chatTopbar"
              visible="false" managed="false"
              styleClass="chat-topbar"
              spacing="10" alignment="CENTER_LEFT">
            <Button text="←" onAction="#voltarParaLista" styleClass="chat-back-btn"/>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label fx:id="chatTitle" text="Conversa" styleClass="chat-title-chat"/>
                <Label fx:id="chatStatusLabel" text="● online" styleClass="chat-subtitle"/>
            </VBox>
        </HBox>
    </top>

    <center>
        <StackPane>

            <!-- Lista de conversas -->
            <ScrollPane fx:id="chatListView"
                        fitToWidth="true" hbarPolicy="NEVER"
                        styleClass="scroll">
                <content>
                    <VBox spacing="18" styleClass="content">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Conversas" styleClass="page-title" HBox.hgrow="ALWAYS"/>
                            <Button text="+ Nova" styleClass="chat-nova-btn"
                                    onAction="#abrirCriarConversa"/>
                        </HBox>
                        <VBox fx:id="conversasContainer" spacing="8"/>
                    </VBox>
                </content>
            </ScrollPane>

            <!-- Criar conversa -->
            <ScrollPane fx:id="criarConversaView"
                        visible="false" managed="false"
                        fitToWidth="true" hbarPolicy="NEVER"
                        styleClass="scroll">
                <content>
                    <VBox spacing="18" styleClass="content">

                        <!-- Header -->
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Button text="←" onAction="#fecharCriarConversa"
                                    styleClass="chat-back-btn"/>
                            <Label text="Nova Conversa" styleClass="page-title"/>
                        </HBox>

                        <VBox spacing="18" styleClass="section">

                            <!-- Toggle Pessoal / Equipe -->
                            <VBox spacing="6">
                                <Label text="Tipo" styleClass="field-label"/>
                                <HBox spacing="8">
                                    <Button fx:id="btnPessoal"
                                            text="👤  Pessoal"
                                            onAction="#selecionarModoPessoal"
                                            styleClass="tipo-toggle-ativo"/>
                                    <Button fx:id="btnEquipe"
                                            text="👥  Equipe / Grupo"
                                            onAction="#selecionarModoEquipe"
                                            styleClass="tipo-toggle-btn"/>
                                </HBox>
                            </VBox>

                            <!-- Nome do grupo (visível só no modo Equipe) -->
                            <VBox fx:id="nomeGrupoBox" spacing="6"
                                  visible="false" managed="false">
                                <Label text="Nome do grupo *" styleClass="field-label"/>
                                <TextField fx:id="nomeGrupoField"
                                           promptText="Ex: Equipe Desenvolvimento"
                                           styleClass="input"/>
                            </VBox>

                            <!-- Participantes -->
                            <VBox spacing="6">
                                <Label fx:id="labelParticipantes"
                                       text="Selecione 1 pessoa"
                                       styleClass="field-label"/>
                                <ListView fx:id="participantesListView"
                                          styleClass="chat-participantes-list"
                                          prefHeight="180"/>
                            </VBox>

                            <!-- Ações -->
                            <HBox spacing="10" alignment="CENTER_RIGHT">
                                <Button text="Cancelar"
                                        onAction="#fecharCriarConversa"
                                        styleClass="chat-cancelar-btn"/>
                                <Button text="Criar Conversa"
                                        onAction="#criarConversa"
                                        styleClass="btn-success"/>
                            </HBox>
                        </VBox>
                    </VBox>
                </content>
            </ScrollPane>

            <!-- Área de mensagens -->
            <ScrollPane fx:id="messagesScrollPane"
                        visible="false" managed="false"
                        fitToWidth="true" hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        styleClass="chat-scroll">
                <content>
                    <VBox fx:id="mensagensContainer" spacing="8"
                          styleClass="chat-messages"/>
                </content>
            </ScrollPane>

            <!-- Loading -->
            <StackPane fx:id="loadingOverlay"
                       visible="false" managed="false"
                       styleClass="loading-overlay" alignment="CENTER">
                <StackPane fx:id="customSpinner" styleClass="custom-spinner"/>
            </StackPane>

        </StackPane>
    </center>

    <!-- Barra de envio -->
    <bottom>
        <HBox fx:id="chatInputBar"
              visible="false" managed="false"
              styleClass="chat-input-bar"
              spacing="10" alignment="CENTER">
            <TextField fx:id="messageField"
                       promptText="Digite uma mensagem..."
                       HBox.hgrow="ALWAYS"
                       onAction="#enviarMensagem"/>
            <Button text="Enviar" onAction="#enviarMensagem"
                    styleClass="chat-send-btn"/>
        </HBox>
    </bottom>

</BorderPane>
