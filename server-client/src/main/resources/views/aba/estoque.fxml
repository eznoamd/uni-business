<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.unibusiness.controller.aba.EstoqueController"
            stylesheets="@../../style/sidebar.css">
    <center>
        <StackPane>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="scroll">
                <content>
                    <VBox spacing="20" styleClass="content">

                        <!-- Header -->
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <VBox HBox.hgrow="ALWAYS" spacing="2">
                                <Label text="Estoque" styleClass="page-title"/>
                                <Label text="Gerencie produtos e movimentações" styleClass="page-subtitle"/>
                            </VBox>
                            <Button text="+ Novo Produto" styleClass="btn-primary"
                                    onAction="#abrirFormNovo"/>
                        </HBox>

                        <!-- KPIs -->
                        <HBox spacing="14">
                            <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="6">
                                <Label text="Total de produtos" styleClass="kpi-label"/>
                                <Label fx:id="lblTotal" text="—" styleClass="kpi-value"/>
                            </VBox>
                            <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="6">
                                <Label text="Estoque baixo (&lt; 5)" styleClass="kpi-label"/>
                                <Label fx:id="lblBaixoEstoque" text="—" styleClass="kpi-value"/>
                                <Label text="produtos críticos" styleClass="kpi-trend-down"/>
                            </VBox>
                        </HBox>

                        <!-- Busca + Tabela -->
                        <VBox styleClass="section" spacing="14">
                            <TextField fx:id="buscaField"
                                       promptText="🔍  Buscar produto..."
                                       styleClass="input" prefWidth="320"/>

                            <TableView fx:id="tabelaProdutos" prefHeight="400">
                                <columns>
                                    <TableColumn fx:id="colId"       text="#"            prefWidth="50"/>
                                    <TableColumn fx:id="colNome"     text="Produto"      prefWidth="180"/>
                                    <TableColumn fx:id="colDescricao" text="Descrição"   prefWidth="220"/>
                                    <TableColumn fx:id="colQtd"      text="Qtd."         prefWidth="90"/>
                                    <TableColumn fx:id="colPreco"    text="Preço Unit."  prefWidth="110"/>
                                    <TableColumn fx:id="colAcoes"    text="Ações"        prefWidth="200"/>
                                </columns>
                            </TableView>
                        </VBox>

                    </VBox>
                </content>
            </ScrollPane>

            <!-- Form overlay -->
            <StackPane fx:id="formOverlay" visible="false" managed="false"
                       style="-fx-background-color: rgba(15,23,42,0.4);" alignment="CENTER">
                <VBox styleClass="section" maxWidth="460" spacing="16">
                    <Label fx:id="formTitulo" text="Novo Produto" styleClass="section-title"/>
                    <VBox spacing="6">
                        <Label text="Nome *" styleClass="field-label"/>
                        <TextField fx:id="fNome" promptText="Nome do produto" styleClass="input"/>
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Descrição" styleClass="field-label"/>
                        <TextField fx:id="fDescricao" promptText="Descrição" styleClass="input"/>
                    </VBox>
                    <HBox spacing="12">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Quantidade inicial" styleClass="field-label"/>
                            <TextField fx:id="fQtd" promptText="0" styleClass="input"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Preço unitário (R$)" styleClass="field-label"/>
                            <TextField fx:id="fPreco" promptText="0.00" styleClass="input"/>
                        </VBox>
                    </HBox>
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button text="Cancelar" onAction="#fecharForm" styleClass="btn-ghost"/>
                        <Button text="Salvar" onAction="#salvarProduto" styleClass="btn-primary"/>
                    </HBox>
                </VBox>
            </StackPane>

            <!-- Movimentar overlay -->
            <StackPane fx:id="movOverlay" visible="false" managed="false"
                       style="-fx-background-color: rgba(15,23,42,0.4);" alignment="CENTER">
                <VBox styleClass="section" maxWidth="380" spacing="16">
                    <Label text="Movimentar Estoque" styleClass="section-title"/>
                    <Label fx:id="movProdutoNome" styleClass="page-subtitle"/>
                    <VBox spacing="6">
                        <Label text="Tipo" styleClass="field-label"/>
                        <ComboBox fx:id="movTipo" maxWidth="Infinity" styleClass="combo-box"/>
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Quantidade" styleClass="field-label"/>
                        <TextField fx:id="movQtd" promptText="Ex: 10" styleClass="input"/>
                    </VBox>
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button text="Cancelar" onAction="#fecharMov" styleClass="btn-ghost"/>
                        <Button text="Confirmar" onAction="#confirmarMovimentacao" styleClass="btn-primary"/>
                    </HBox>
                </VBox>
            </StackPane>

            <!-- Loading -->
            <StackPane fx:id="loadingOverlay" visible="false" managed="false"
                       styleClass="loading-overlay" alignment="CENTER">
                <StackPane fx:id="customSpinner" styleClass="custom-spinner"/>
            </StackPane>
        </StackPane>
    </center>
</BorderPane>
