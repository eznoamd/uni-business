<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="com.unibusiness.controller.DashboardController"
    prefWidth="1280" prefHeight="720"
    stylesheets="@../style/sidebar.css">

    <left>
        <VBox spacing="12" styleClass="sidebar">

            <HBox styleClass="logo-placeholder" alignment="CENTER" spacing="8">
                <Label text="UniBusiness" styleClass="logo-text"/>
            </HBox>

            <ScrollPane fitToWidth="true" vbarPolicy="NEVER" hbarPolicy="NEVER"
                        styleClass="sidebar-scroll" VBox.vgrow="ALWAYS">
                <VBox spacing="16" styleClass="sidebar-scroll-content">

                    <VBox styleClass="sidebar-section">
                        <Label text="Pessoal" styleClass="sidebar-section-title"/>
                        <VBox styleClass="sidebar-section-items">
                            <Button text="Home" styleClass="sidebar-item" onAction="#switchToHome">
                                <graphic><FontIcon iconLiteral="fas-home"/></graphic>
                            </Button>
                            <Button text="Minhas Tarefas" styleClass="sidebar-item" onAction="#switchToMinhasTarefas">
                                <graphic><FontIcon iconLiteral="fas-check-square"/></graphic>
                            </Button>
                            <Button text="Chat" styleClass="sidebar-item" onAction="#switchToChat">
                                <graphic><FontIcon iconLiteral="fas-comments"/></graphic>
                            </Button>
                        </VBox>
                    </VBox>

                    <VBox styleClass="sidebar-section">
                        <Label text="Operacional" styleClass="sidebar-section-title"/>
                        <VBox styleClass="sidebar-section-items">
                            <Button text="Estoque" styleClass="sidebar-item" onAction="#switchToEstoque">
                                <graphic><FontIcon iconLiteral="fas-boxes"/></graphic>
                            </Button>
                            <Button text="Financeiro" styleClass="sidebar-item" onAction="#switchToFinanceiro">
                                <graphic><FontIcon iconLiteral="fas-chart-line"/></graphic>
                            </Button>
                            <Button text="Clientes" styleClass="sidebar-item" onAction="#switchToClientes">
                                <graphic><FontIcon iconLiteral="fas-users"/></graphic>
                            </Button>
                            <Button text="Fornecedores" styleClass="sidebar-item" onAction="#switchToFornecedores">
                                <graphic><FontIcon iconLiteral="fas-truck"/></graphic>
                            </Button>
                        </VBox>
                    </VBox>

                    <VBox styleClass="sidebar-section">
                        <Label text="Administração" styleClass="sidebar-section-title"/>
                        <VBox styleClass="sidebar-section-items">
                            <Button text="Funcionários" styleClass="sidebar-item" onAction="#switchToFuncionarios">
                                <graphic><FontIcon iconLiteral="fas-user-tie"/></graphic>
                            </Button>
                            <Button text="Tarefas" styleClass="sidebar-item" onAction="#switchToTarefas">
                                <graphic><FontIcon iconLiteral="fas-tasks"/></graphic>
                            </Button>
                            <Button text="Equipes" styleClass="sidebar-item" onAction="#switchToEquipes">
                                <graphic><FontIcon iconLiteral="fas-layer-group"/></graphic>
                            </Button>
                        </VBox>
                    </VBox>

                </VBox>
            </ScrollPane>

            <HBox spacing="10" styleClass="profile-card" alignment="CENTER_LEFT">
                <StackPane styleClass="profile-photo">
                    <Label fx:id="profileInitial" text="?" styleClass="profile-initial"/>
                </StackPane>
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label fx:id="profileName" text="Usuário" styleClass="profile-name"/>
                    <Label fx:id="profileRole" text="Sistema" styleClass="profile-role"/>
                </VBox>
            </HBox>

        </VBox>
    </left>

    <center>
        <BorderPane fx:id="mainLayout" styleClass="content-area"/>
    </center>

</BorderPane>
